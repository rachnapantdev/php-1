Keys :
1. Primary Key : To make a column unique
2. Foreign Key : Link one table to another
_________________________________________________________________

create table tableName(colName data type primary key, ...);

Example

CREATE TABLE dept(did int PRIMARY KEY, dname varchar(33));

INSERT into dept(did, dname)
VALUES(1,'HR'),
(2,'IT'),
(3,'Sales'),
(4,'Marketing')

CREATE TABLE emp(eid int PRIMARY key AUTO_INCREMENT, ename varchar(33), city varchar(33), edid int, FOREIGN KEY(edid) REFERENCES dept(did) )

INSERT into emp(ename, city, edid)
VALUES('Aman','Delhi',2),
('Naman','Noida',1),
('Suman','Gurgaon',1),
('Mohit','Nainital',4)
